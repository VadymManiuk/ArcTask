{
  "name": "arctask",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "contracts:compile": "node scripts/deploy-arc-testnet.mjs --compile-only",
    "contracts:deploy:arc": "node scripts/deploy-arc-testnet.mjs",
    "contracts:smoke:arc": "node scripts/smoke-arc-testnet.mjs",
    "agent:worker": "node scripts/agent-worker.mjs",
    "agent:worker:once": "ARC_AGENT_ONCE=true node scripts/agent-worker.mjs",
    "agent:worker:live": "ARC_AGENT_DRY_RUN=false node scripts/agent-worker.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "viem": "^2.21.45",
    "wagmi": "^2.12.30"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "solc": "^0.8.35",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
