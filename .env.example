# Production defaults to Arc Testnet onchain mode.
NEXT_PUBLIC_ARC_MODE=onchain

# Use mock for local no-wallet demos.
# NEXT_PUBLIC_ARC_MODE=mock

# Arc Testnet contract addresses. These public defaults are also embedded in lib/arc-config.ts.
NEXT_PUBLIC_ERC8004_REGISTRY_ADDRESS=0xe69e88cb35a831fca783ac56405831478fdbaa41
NEXT_PUBLIC_ERC8183_ESCROW_ADDRESS=0x2b3e0b7a7d96f8199fe31b2867358990430b5181
NEXT_PUBLIC_USDC_ADDRESS=native

# Local-only deploy key. Never commit .env.local and never paste this key into chat.
ARC_TESTNET_DEPLOYER_PRIVATE_KEY=
