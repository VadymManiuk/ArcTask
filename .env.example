# Production defaults to Arc Testnet onchain mode.
NEXT_PUBLIC_ARC_MODE=onchain

# Use mock for local no-wallet demos.
# NEXT_PUBLIC_ARC_MODE=mock

# Arc Testnet contract addresses. These public defaults are also embedded in lib/arc-config.ts.
NEXT_PUBLIC_ERC8004_REGISTRY_ADDRESS=0x4ab5791a689b15126fcc7a549f8e4c7e16c5e0b8
NEXT_PUBLIC_ERC8183_ESCROW_ADDRESS=0x58ca473df727301bce771d6087f883364c83a3b6
NEXT_PUBLIC_USDC_ADDRESS=native

# Local-only deploy key. Never commit .env.local and never paste this key into chat.
ARC_TESTNET_DEPLOYER_PRIVATE_KEY=

# Local-only autonomous worker key. Use a dedicated funded agent-owner wallet.
# Worker defaults to dry-run unless ARC_AGENT_DRY_RUN=false is set.
ARC_AGENT_PRIVATE_KEY=
ARC_AGENT_DRY_RUN=true
# Never enable deployer fallback outside one-off local testing.
ARC_AGENT_ALLOW_DEPLOYER_FALLBACK=false
# ARC_AGENT_ONCE=true
ARC_AGENT_POLL_INTERVAL_MS=15000
ARC_AGENT_MAX_JOBS_PER_TICK=5
ARC_AGENT_MAX_JOB_PAYLOAD_CHARS=8000

# Optional Vercel -> VPS fallback for worker deliverables and status.
ARCTASK_DELIVERABLE_REMOTE_BASE_URL=
# Shared server-to-server token for the fallback above.
ARCTASK_DELIVERABLE_REMOTE_TOKEN=
# Stable HMAC secret for one-time deliverable access challenges. Set the same value on every web runtime.
ARCTASK_ACCESS_NONCE_SECRET=
# Optional token for full /api/worker/status details. Public responses are sanitized.
ARCTASK_ADMIN_TOKEN=

# Optional AI executor for autonomous deliverables. Do not commit real keys.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_OUTPUT_TOKENS=1800
# Set true when autonomous jobs should discover current public market data, such as upcoming TGE tokens.
ARC_AGENT_ENABLE_WEB_SEARCH=false
ARC_AGENT_WEB_SEARCH_CONTEXT=low
