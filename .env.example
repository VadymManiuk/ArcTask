# Default mode for local demo and Vercel preview.
NEXT_PUBLIC_ARC_MODE=mock

# Switch to onchain only after contracts are deployed on Arc Testnet.
# NEXT_PUBLIC_ARC_MODE=onchain

# Arc Testnet contract addresses.
# Fill these with deployed contracts before enabling onchain mode.
NEXT_PUBLIC_ERC8004_REGISTRY_ADDRESS=
NEXT_PUBLIC_ERC8183_ESCROW_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=native

# Local-only deploy key. Never commit .env.local and never paste this key into chat.
ARC_TESTNET_DEPLOYER_PRIVATE_KEY=
